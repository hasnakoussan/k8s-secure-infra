            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "controller:\n  hostNetwork: true\n  kind: DaemonSet\n  service:\n    type: NodePort\n  nodeSelector:\n    ingress-ready: \"true\"\n  tolerations:\n    - key: node-role.kubernetes.io/control-plane\n      operator: Equal\n      effect: NoSchedule\n  resources:\n    requests:\n      cpu: 50m\n      memory: 64Mi\n"
